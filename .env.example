APP_NAME=Construction Management System with AI
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000

# Database (MySQL)
DB_NAME=construction_management
DB_USER=root
DB_PASSWORD=root
DB_HOST=localhost
DB_PORT=3306

# Async SQLAlchemy driver (mysql+asyncmy)
# Alembic uses the sync driver (mysql+pymysql) from the same settings.
SQL_ECHO=false

# JWT
JWT_SECRET=change_me_to_a_long_random_secret
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60

# Redis (for caching + rate limiting)
REDIS_URL=redis://localhost:6379/0
REDIS_CACHE_TTL_SECONDS=300

# Rate limiting defaults
RATE_LIMIT_TIMES=60
RATE_LIMIT_SECONDS=60

